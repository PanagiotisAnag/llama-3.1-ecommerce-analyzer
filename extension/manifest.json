{
  "manifest_version": 3,
  "name": "MarketLens",
  "version": "2.0",
  "description": "AI-powered product intelligence for e-commerce sellers",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.de/*",
    "https://www.temu.com/*",
    "https://www.aliexpress.com/*",
    "https://www.alibaba.com/*",
    "https://www.ebay.com/*",
    "https://www.walmart.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.temu.com/*",
        "https://www.aliexpress.com/*",
        "https://www.alibaba.com/*",
        "https://www.ebay.com/*",
        "https://www.walmart.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
